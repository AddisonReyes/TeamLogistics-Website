---
const stats = [
  {
    value: "+100",
    label: "Puntos logísticos conectados",
  },
  {
    value: "+50",
    label: "Mercados atendidos",
  },
  {
    value: "24 h",
    label: "Tiempo de respuesta comercial",
  },
  {
    value: "1",
    label: "Equipo coordinando todo el proceso",
  },
];
---

<section class="stats-section">
  <div class="pattern-overlay"></div>
  <div class="container">
    <div class="intro">
      <div>
        <span class="eyebrow">Cobertura y control</span>
        <h2 class="title">Una operación sólida necesita visibilidad, no solo movimiento</h2>
      </div>
      <p class="description">
        Nuestra red nos permite conectar origen, tránsito y destino con una
        lectura más ejecutiva del embarque: documentación, tiempos, costos y
        seguimiento en un mismo frente.
      </p>
    </div>
    <div class="stats-grid">
      {
        stats.map((stat) => (
          <div class="stat-card">
            <div class="stat-value">{stat.value}</div>
            <div class="stat-label">{stat.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .stats-section {
    padding: 6rem 0;
    background:
      linear-gradient(135deg, var(--brand-navy) 0%, #17305a 100%);
    color: var(--brand-white);
    overflow: hidden;
    position: relative;
  }

  .pattern-overlay {
    position: absolute;
    inset: 0;
    opacity: 0.16;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
    background-size: 56px 56px;
    pointer-events: none;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1rem;
    position: relative;
    z-index: 10;
  }

  @media (min-width: 640px) {
    .container {
      padding: 0 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .container {
      padding: 0 2rem;
    }
  }

  .intro {
    display: grid;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .eyebrow {
    display: inline-flex;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.95rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(240, 219, 191, 0.9);
    margin-bottom: 0.9rem;
  }

  .title {
    font-size: clamp(2rem, 5vw, 3.3rem);
    font-weight: 800;
    margin-bottom: 0;
    letter-spacing: -0.05em;
    line-height: 1.06;
    max-width: 38rem;
  }

  .description {
    font-size: 1rem;
    color: rgba(219, 234, 254, 0.84);
    max-width: 36rem;
    line-height: 1.85;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  @media (min-width: 900px) {
    .intro {
      grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.8fr);
      align-items: end;
      gap: 2rem;
    }

    .stats-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .stat-card {
    padding: 1.4rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 1.2rem;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: all 0.3s ease;
  }

  .stat-card:hover {
    transform: translateY(-3px);
    border-color: rgba(240, 219, 191, 0.28);
    background-color: rgba(255, 255, 255, 0.08);
  }

  .stat-value {
    font-size: 2.2rem;
    font-weight: 800;
    margin-bottom: 0.65rem;
    color: #f0dbbf;
    letter-spacing: -0.06em;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.76);
  }

  @media (max-width: 560px) {
    .stats-section {
      padding: 5rem 0;
    }

    .intro {
      margin-bottom: 2rem;
    }

    .title {
      font-size: 1.9rem;
    }

    .description {
      font-size: 0.95rem;
      line-height: 1.7;
    }

    .stats-grid {
      grid-template-columns: 1fr;
    }

    .stat-card {
      padding: 1.15rem;
      border-radius: 1rem;
    }

    .stat-value {
      font-size: 1.8rem;
    }

    .stat-label {
      font-size: 0.76rem;
    }
  }
</style>
