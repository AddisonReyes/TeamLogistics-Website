---
import Icon from "./common/Icon.astro";

type FAQGroupIcon = "building" | "clipboard" | "users";

interface FAQItem {
  answer: string;
  question: string;
}

interface FAQGroup {
  category: string;
  icon: FAQGroupIcon;
  items: FAQItem[];
}

const faqs = [
  {
    category: "Empresa",
    icon: "building",
    items: [
      {
        question: "¿Quién es Team Logistics?",
        answer:
          "Somos un operador logístico global con sede en República Dominicana. Nuestra red se extiende por los cinco continentes, facilitando el movimiento de carga desde y hacia cualquier parte del mundo con soluciones integrales de consolidación.",
      },
      {
        question: "¿Cuál es el alcance geográfico de sus servicios?",
        answer:
          "Operamos de manera global. Aunque somos líderes en el corredor Caribe-Centroamérica, gestionamos importaciones y exportaciones con Europa, Asia, Norteamérica y Suramérica, conectando los principales puertos y aeropuertos del mundo.",
      },
    ],
  },
  {
    category: "Procedimientos",
    icon: "clipboard",
    items: [
      {
        question: "¿Cómo funciona la consolidación de carga (LCL)?",
        answer:
          "LCL (Less than Container Load) permite a varios clientes compartir el espacio de un mismo contenedor. Usted solo paga por los metros cúbicos o kilos que ocupa su mercancía, lo que elimina la necesidad de alquilar un contenedor completo si su carga es pequeña.",
      },
      {
        question: "¿Cuál es el proceso para realizar un envío?",
        answer:
          "El proceso es simple: 1. Solicita una cotización. 2. Entrega la mercancía en nuestros almacenes o solicitamos una recogida. 3. Consolidamos su carga con otros envíos. 4. Realizamos el despacho aduanal y el envío internacional. 5. Notificamos la llegada al destino final.",
      },
    ],
  },
  {
    category: "Dudas de Clientes",
    icon: "users",
    items: [
      {
        question: "¿Qué documentos necesito para importar?",
        answer:
          "Generalmente requerimos la factura comercial original, la lista de empaque (packing list) y, dependiendo del tipo de mercancía, certificados de origen o permisos especiales de salud o agricultura.",
      },
      {
        question: "¿Puedo rastrear mi mercancía en tiempo real?",
        answer:
          "Sí, contamos con un sistema de monitoreo 24/7. Proporcionamos actualizaciones constantes sobre el estatus de su carga desde que sale de origen hasta que llega a sus manos.",
      },
    ],
  },
] satisfies FAQGroup[];
---

<section id="faq" class="faq-section">
  <div class="container">
    <div class="header">
      <div class="badge">Centro de ayuda</div>
      <h2 class="title">Respuestas claras antes de su próximo embarque</h2>
      <p class="description">
        Resumimos las preguntas que más suelen aparecer al momento de cotizar,
        consolidar y coordinar una operación internacional.
      </p>
    </div>

    <div class="faq-groups">
      {
        faqs.map((group) => (
          <div class="faq-group">
            <div class="group-header">
              <span class="group-icon">
                <Icon name={group.icon} size={20} />
              </span>
              <h3 class="group-title">{group.category}</h3>
            </div>
            <div class="faq-items">
              {group.items.map((faq) => (
                <div class="faq-item">
                  <button class="faq-button" type="button">
                    <span class="faq-question">{faq.question}</span>
                    <Icon name="chevron-down" class="faq-chevron" size={24} />
                  </button>
                  <div class="faq-answer">
                    <div class="faq-answer-content">{faq.answer}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq-section {
    padding: 6.5rem 0;
    background: linear-gradient(180deg, #ffffff 0%, #f7f9fc 100%);
  }

  .container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 640px) {
    .container {
      padding: 0 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .container {
      padding: 0 2rem;
    }
  }

  .header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .badge {
    display: inline-flex;
    padding: 0.55rem 0.85rem;
    background-color: rgba(33, 75, 143, 0.08);
    color: var(--brand-blue);
    border-radius: 9999px;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    color: var(--brand-ink);
    margin-bottom: 1rem;
    line-height: 1.06;
    letter-spacing: -0.05em;
  }

  .description {
    font-size: 1rem;
    color: var(--brand-muted);
    max-width: 42rem;
    margin: 0 auto;
    line-height: 1.8;
  }

  .faq-groups {
    display: grid;
    gap: 1.5rem;
  }

  @media (min-width: 960px) {
    .faq-groups {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      align-items: start;
    }
  }

  .group-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .group-icon {
    color: var(--brand-red);
    display: flex;
    align-items: center;
    width: 2.4rem;
    height: 2.4rem;
    justify-content: center;
    border-radius: 0.9rem;
    background: rgba(195, 71, 63, 0.1);
  }

  .group-title {
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand-ink);
    margin: 0;
  }

  .faq-items {
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 1.35rem;
    box-shadow: var(--shadow-soft);
    border: 1px solid rgba(15, 23, 42, 0.08);
    padding: 0 1.25rem;
  }

  .faq-item {
    border-bottom: 1px solid #e5e7eb;
    padding: 1.15rem 0;
  }

  .faq-item:last-child {
    border-bottom: none;
  }

  .faq-button {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    text-align: left;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    outline: none;
  }

  .faq-question {
    font-size: 1rem;
    font-weight: 700;
    color: var(--brand-ink);
    transition: color 0.3s ease;
    padding-right: 1rem;
    line-height: 1.5;
  }

  .faq-button:hover .faq-question {
    color: var(--brand-blue);
  }

  .faq-item.open .faq-question {
    color: var(--brand-blue);
  }

  .faq-chevron {
    width: 1.5rem;
    height: 1.5rem;
    color: #9ca3af;
    flex-shrink: 0;
    transition: all 0.3s ease;
  }

  .faq-item.open .faq-chevron {
    transform: rotate(180deg);
    color: var(--brand-red);
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .faq-item.open .faq-answer {
    max-height: 500px;
  }

  .faq-answer-content {
    padding-top: 1rem;
    padding-bottom: 0.35rem;
    color: var(--brand-muted);
    line-height: 1.75;
    font-size: 0.95rem;
  }

  @media (max-width: 560px) {
    .faq-section {
      padding: 5rem 0;
    }

    .header {
      margin-bottom: 2.4rem;
    }

    .title {
      font-size: 1.9rem;
    }

    .description {
      font-size: 0.95rem;
      line-height: 1.7;
    }

    .faq-groups {
      gap: 1rem;
    }

    .faq-items {
      padding: 0 1rem;
      border-radius: 1rem;
    }

    .faq-item {
      padding: 1rem 0;
    }

    .faq-question {
      font-size: 0.95rem;
      line-height: 1.45;
    }

    .faq-answer-content {
      font-size: 0.9rem;
      line-height: 1.65;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const faqGroups = document.querySelectorAll<HTMLElement>(".faq-items");

    faqGroups.forEach((group) => {
      group.addEventListener("click", (event) => {
        const target = event.target as HTMLElement;
        const button = target.closest<HTMLButtonElement>(".faq-button");

        if (!button) {
          return;
        }

        const currentItem = button.closest<HTMLElement>(".faq-item");
        const wasOpen = currentItem?.classList.contains("open");

        group.querySelectorAll<HTMLElement>(".faq-item").forEach((item) => {
          item.classList.remove("open");
        });

        if (currentItem && !wasOpen) {
          currentItem.classList.add("open");
        }
      });
    });
  });
</script>
