---
const imageUrl =
  "https://images.unsplash.com/photo-1619070284836-e850273d69ac?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxsb2dpc3RpY3MlMjB3YXJlaG91c2UlMjBzdG9yYWdlfGVufDF8fHx8MTc3MDMzODI0Mnww&ixlib=rb-4.1.0&q=80&w=1080";

const features = [
  {
    title: "Planeación antes de embarcar",
    description:
      "Definimos alcance, ruta y documentación antes de mover la carga para reducir ajustes de última hora.",
  },
  {
    title: "Visibilidad durante el tránsito",
    description:
      "Centralizamos actualizaciones y seguimiento para que su equipo tenga claridad comercial y operativa.",
  },
  {
    title: "Soporte local con criterio",
    description:
      "Acompañamos decisiones en origen, tránsito y destino con enfoque práctico para importadores y distribuidores.",
  },
  {
    title: "Costos mejor estructurados",
    description:
      "La consolidación permite alinear volumen y presupuesto sin sobredimensionar la operación.",
  },
];
---

<section id="about" class="features-section">
  <div class="container">
    <div class="content-wrapper">
      <div class="image-column">
        <div class="image-wrapper">
          <img
            src={imageUrl}
            alt="Centro logístico y operación de almacenaje"
            class="main-image"
            loading="lazy"
          />
        </div>

        <div class="stats-badge">
          <div class="stats-number">LCL</div>
          <div class="stats-label">Consolidación con lectura comercial y operativa</div>
        </div>
      </div>

      <div class="text-column">
        <h2 class="subtitle">Por qué Team Logistics</h2>
        <h3 class="title">Menos improvisación, más estructura en cada movimiento</h3>
        <p class="description">
          La diferencia no está solo en mover carga. Está en ordenar la
          operación para que su empresa tome decisiones con mejor información,
          mejores tiempos de respuesta y menos fricción documental.
        </p>

        <div class="features-list">
          {
            features.map((item) => (
              <article class="feature-item">
                <span class="feature-marker"></span>
                <div>
                  <h4 class="feature-heading">{item.title}</h4>
                  <p class="feature-text">{item.description}</p>
                </div>
              </article>
            ))
          }
        </div>

        <a href="#contact" class="cta-button">Hablar con un asesor logístico</a>
      </div>
    </div>
  </div>
</section>

<style>
  .features-section {
    padding: 6.5rem 0;
    background:
      radial-gradient(circle at left top, rgba(195, 71, 63, 0.08), transparent 24%),
      linear-gradient(180deg, #fbfcfe 0%, #f2f5fa 100%);
    overflow: hidden;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 640px) {
    .container {
      padding: 0 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .container {
      padding: 0 2rem;
    }
  }

  .content-wrapper {
    display: grid;
    gap: 3rem;
    align-items: center;
  }

  .image-column {
    width: 100%;
    position: relative;
    order: 2;
  }

  .image-wrapper {
    position: relative;
    z-index: 10;
    border-radius: 1.6rem;
    overflow: hidden;
    box-shadow: var(--shadow-strong);
  }

  .main-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  .stats-badge {
    position: absolute;
    right: 1.25rem;
    bottom: 1.25rem;
    max-width: 16rem;
    background: rgba(255, 253, 249, 0.94);
    padding: 1.15rem 1.2rem;
    border-radius: 1rem;
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: var(--shadow-soft);
    z-index: 20;
  }

  .stats-number {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--brand-blue);
    letter-spacing: 0.08em;
    line-height: 1;
  }

  .stats-label {
    font-size: 0.875rem;
    color: var(--brand-muted);
    line-height: 1.6;
    margin-top: 0.45rem;
  }

  .text-column {
    width: 100%;
    order: 1;
  }

  @media (min-width: 1024px) {
    .content-wrapper {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
      gap: 4rem;
    }

    .image-column {
      order: 1;
    }

    .text-column {
      order: 2;
    }
  }

  .subtitle {
    color: var(--brand-red);
    font-family: "Barlow Condensed", sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    letter-spacing: -0.05em;
    line-height: 1.06;
    color: var(--brand-ink);
    margin-bottom: 1.4rem;
  }

  .description {
    font-size: 1rem;
    color: var(--brand-muted);
    margin-bottom: 2rem;
    line-height: 1.85;
    max-width: 38rem;
  }

  .features-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 2.2rem;
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 0.95rem;
    padding: 1.15rem;
    border-radius: 1.2rem;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background: rgba(255, 255, 255, 0.72);
    box-shadow: 0 12px 24px rgba(15, 23, 42, 0.04);
  }

  .feature-marker {
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--brand-red), #e5b4a7);
    flex-shrink: 0;
    margin-top: 0.5rem;
    box-shadow: 0 0 0 8px rgba(195, 71, 63, 0.08);
  }

  .feature-heading {
    font-size: 1rem;
    color: var(--brand-ink);
    font-weight: 700;
    margin-bottom: 0.35rem;
    letter-spacing: -0.02em;
  }

  .feature-text {
    color: var(--brand-muted);
    line-height: 1.7;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--brand-blue), var(--brand-navy));
    color: var(--brand-white);
    padding: 1rem 1.4rem;
    border-radius: 999px;
    font-weight: 700;
    text-decoration: none;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
    box-shadow: 0 18px 34px rgba(17, 33, 61, 0.18);
    font-size: 0.95rem;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 24px 44px rgba(17, 33, 61, 0.22);
  }

  @media (max-width: 560px) {
    .features-section {
      padding: 5rem 0;
    }

    .content-wrapper {
      gap: 2rem;
    }

    .image-wrapper {
      border-radius: 1.15rem;
    }

    .stats-badge {
      position: static;
      max-width: none;
      margin-top: 0.9rem;
      padding: 1rem;
    }

    .title {
      font-size: 1.9rem;
    }

    .description {
      font-size: 0.95rem;
      line-height: 1.7;
      margin-bottom: 1.5rem;
    }

    .feature-item {
      padding: 1rem;
      border-radius: 1rem;
    }

    .feature-heading {
      font-size: 0.95rem;
    }

    .feature-text {
      font-size: 0.9rem;
      line-height: 1.6;
    }

    .cta-button {
      width: 100%;
      padding: 0.95rem 1.1rem;
      font-size: 0.92rem;
    }
  }
</style>
