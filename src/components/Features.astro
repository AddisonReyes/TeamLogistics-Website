---
// Puedes pasar la imagen como prop si lo necesitas
const imageUrl =
  "https://images.unsplash.com/photo-1619070284836-e850273d69ac?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxsb2dpc3RpY3MlMjB3YXJlaG91c2UlMjBzdG9yYWdlfGVufDF8fHx8MTc3MDMzODI0Mnww&ixlib=rb-4.1.0&q=80&w=1080";

const features = [
  "Consolidación semanal garantizada desde los principales puertos.",
  "Red de transporte propia en toda la región del Caribe.",
  "Seguimiento en tiempo real de su mercancía.",
  "Especialistas en normativa aduanal dominicana.",
  "Costos transparentes sin cargos ocultos.",
];
---

<section id="about" class="features-section">
  <div class="container">
    <div class="content-wrapper">
      <!-- Image Column -->
      <div class="image-column">
        <div class="image-wrapper">
          <img
            src={imageUrl}
            alt="Logistics Efficiency"
            class="main-image"
            loading="lazy"
          />
        </div>
        <div class="bg-decoration bg-blue"></div>
        <div class="bg-decoration bg-red"></div>

        <div class="stats-badge">
          <div class="stats-number">100%</div>
          <div class="stats-label">CONFIDENCIALIDAD</div>
        </div>
      </div>

      <!-- Content Column -->
      <div class="text-column">
        <h2 class="subtitle">Por Qué Elegirnos</h2>
        <h3 class="title">Pague Solo por el Espacio que Utiliza</h3>
        <p class="description">
          En Team Logistics entendemos que no todos los negocios necesitan
          enviar un contenedor completo. Por eso nos especializamos en la
          consolidación de carga, permitiéndole optimizar sus costos operativos
          de manera significativa.
        </p>

        <ul class="features-list">
          {
            features.map((item) => (
              <li class="feature-item">
                <svg
                  class="check-icon"
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                  <polyline points="22 4 12 14.01 9 11.01" />
                </svg>
                <span class="feature-text">{item}</span>
              </li>
            ))
          }
        </ul>

        <button class="cta-button"> Conocer Más Sobre Nosotros </button>
      </div>
    </div>
  </div>
</section>

<style>
  .features-section {
    padding: 6rem 0;
    background-color: #f9fafb;
    overflow: hidden;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 640px) {
    .container {
      padding: 0 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .container {
      padding: 0 2rem;
    }
  }

  .content-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4rem;
  }

  @media (min-width: 1024px) {
    .content-wrapper {
      flex-direction: row;
    }
  }

  /* Image Column */
  .image-column {
    width: 100%;
    position: relative;
  }

  @media (min-width: 1024px) {
    .image-column {
      width: 50%;
    }
  }

  .image-wrapper {
    position: relative;
    z-index: 10;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
  }

  .main-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  .bg-decoration {
    position: absolute;
    width: 16rem;
    height: 16rem;
    border-radius: 1rem;
    z-index: 0;
    opacity: 0.1;
  }

  .bg-decoration.bg-blue {
    bottom: -2rem;
    right: -2rem;
    background-color: var(--brand-blue, #1e40af);
  }

  .bg-decoration.bg-red {
    top: -2rem;
    left: -2rem;
    background-color: var(--brand-red, #dc2626);
  }

  .stats-badge {
    display: none;
    position: absolute;
    bottom: 2rem;
    left: 2rem;
    background-color: #ffffff;
    padding: 1.5rem;
    border-radius: 0.75rem;
    box-shadow:
      0 10px 15px -3px rgba(0, 0, 0, 0.1),
      0 4px 6px -2px rgba(0, 0, 0, 0.05);
    z-index: 20;
  }

  @media (min-width: 640px) {
    .stats-badge {
      display: block;
    }
  }

  .stats-number {
    font-size: 1.875rem;
    font-weight: 700;
    color: var(--brand-blue, #1e40af);
    line-height: 1;
  }

  .stats-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--brand-gray, #6b7280);
    letter-spacing: 0.05em;
    margin-top: 0.25rem;
  }

  /* Text Column */
  .text-column {
    width: 100%;
  }

  @media (min-width: 1024px) {
    .text-column {
      width: 50%;
    }
  }

  .subtitle {
    color: var(--brand-red, #dc2626);
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .title {
    font-size: 1.875rem;
    font-weight: 700;
    color: var(--brand-blue, #1e40af);
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .title {
      font-size: 2.25rem;
    }
  }

  .description {
    font-size: 1.125rem;
    color: var(--brand-gray, #6b7280);
    margin-bottom: 2rem;
    line-height: 1.625;
  }

  .features-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .check-icon {
    width: 1.5rem;
    height: 1.5rem;
    color: var(--brand-red, #dc2626);
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .feature-text {
    color: var(--brand-gray, #6b7280);
    font-weight: 500;
    line-height: 1.5;
  }

  .cta-button {
    background-color: var(--brand-blue, #1e40af);
    color: #ffffff;
    padding: 1rem 2.5rem;
    border-radius: 0.5rem;
    font-weight: 700;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 10px 15px -3px rgba(30, 64, 175, 0.2);
    font-size: 1rem;
  }

  .cta-button:hover {
    background-color: rgba(30, 64, 175, 0.9);
    transform: translateY(-2px);
    box-shadow: 0 15px 20px -5px rgba(30, 64, 175, 0.3);
  }

  .cta-button:active {
    transform: translateY(0);
  }
</style>
