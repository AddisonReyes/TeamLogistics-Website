---
import Icon from "./common/Icon.astro";

const sectors = ["Retail", "Industria", "Distribución"];

const operations = [
  {
    label: "Cobertura clave",
    value: "Caribe, América y Europa",
  },
  {
    label: "Tiempo de respuesta",
    value: "Cotizaciones en menos de 24 h",
  },
  {
    label: "Operativas",
    value: "LCL, FCL, aérea y terrestre",
  },
];

const heroStats = [
  {
    value: "15+",
    label: "Años acompañando importadores y distribuidores",
  },
  {
    value: "24 h",
    label: "para estructurar cotizaciones con alcance claro",
  },
  {
    value: "1 equipo",
    label: "local para coordinar origen, tránsito y entrega",
  },
];
---

<section id="home" class="hero-container">
  <div class="hero-background">
    <img
      src="https://images.unsplash.com/photo-1663801563712-ebf3c6a78239?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxjYXJnbyUyMHNoaXAlMjBvY2VhbnxlbnwxfHx8fDE3NzAyNjk3OTN8MA&ixlib=rb-4.1.0&q=80&w=1920"
      alt="Operación marítima internacional"
      class="hero-image"
    />
    <div class="hero-overlay"></div>
    <div class="hero-grid"></div>
  </div>

  <div class="hero-content">
    <div class="hero-text">
      <div class="eyebrow">República Dominicana · Freight Forwarding</div>

      <h1 class="hero-title">
        Logística internacional con <span class="highlight"
          >criterio operativo</span
        >
      </h1>

      <p class="hero-description">
        Diseñamos embarques claros, trazables y rentables para empresas que
        necesitan mover carga con orden, visibilidad y respuesta local.
      </p>

      <div class="hero-buttons">
        <a href="#contact" class="btn-primary">
          Solicitar cotización
          <Icon name="chevron-right" class="chevron" size={20} />
        </a>
        <a href="#services" class="btn-secondary">Ver soluciones</a>
      </div>

      <div class="hero-sectors">
        {sectors.map((sector) => <span>{sector}</span>)}
      </div>

      <div class="stats">
        {
          heroStats.map((stat) => (
            <div class="stat-item">
              <div class="stat-number">{stat.value}</div>
              <div class="stat-label">{stat.label}</div>
            </div>
          ))
        }
      </div>
    </div>

    <aside class="hero-panel">
      <div class="panel-tag">Visión operativa</div>
      <h2 class="panel-title">
        Un solo frente para coordinar su cadena logística
      </h2>
      <p class="panel-description">
        Menos improvisación, más estructura comercial y seguimiento en cada
        etapa del embarque.
      </p>

      <div class="panel-list">
        {
          operations.map((item) => (
            <div class="panel-item">
              <span class="panel-label">{item.label}</span>
              <strong class="panel-value">{item.value}</strong>
            </div>
          ))
        }
      </div>

      <div class="panel-footer">
        <span class="panel-footer-label">Enfoque</span>
        <span class="panel-footer-value"
          >Consolidación, control documental y ejecución confiable</span
        >
      </div>
    </aside>
  </div>
</section>

<style>
  .hero-container {
    position: relative;
    min-height: 100svh;
    display: flex;
    overflow: hidden;
    padding: 9.5rem 0 4.5rem;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        100deg,
        rgba(14, 26, 48, 0.96) 0%,
        rgba(17, 33, 61, 0.88) 42%,
        rgba(17, 33, 61, 0.45) 68%,
        rgba(17, 33, 61, 0.2) 100%
      ),
      linear-gradient(180deg, rgba(13, 21, 39, 0.12), rgba(13, 21, 39, 0.7));
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.06) 1px, transparent 1px);
    background-size: 58px 58px;
    opacity: 0.2;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.9), transparent 85%);
    -webkit-mask-image: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.9),
      transparent 85%
    );
  }

  .hero-content {
    position: relative;
    z-index: 10;
    width: min(1280px, 100%);
    margin: 0 auto;
    padding: 0 1rem;
    display: grid;
    gap: 2.5rem;
    align-items: end;
  }

  .hero-text {
    max-width: 43rem;
    color: var(--brand-white);
    animation: fadeInLeft 0.8s ease-out;
  }

  @keyframes fadeInLeft {
    from {
      opacity: 0;
      transform: translateX(-50px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .eyebrow {
    display: inline-flex;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.78);
    margin-bottom: 1.3rem;
  }

  .hero-title {
    font-size: clamp(2.8rem, 7vw, 5.6rem);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: -0.06em;
    margin-bottom: 1.35rem;
  }

  .highlight {
    color: #f0dbbf;
  }

  .hero-description {
    max-width: 38rem;
    font-size: 1.08rem;
    color: rgba(255, 255, 255, 0.78);
    margin-bottom: 2rem;
  }

  .hero-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--brand-red), #9e352f);
    color: var(--brand-white);
    padding: 1rem 1.45rem;
    border-radius: 999px;
    font-size: 0.98rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    text-decoration: none;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      background 0.25s ease;
    box-shadow: 0 22px 44px rgba(159, 57, 49, 0.26);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 28px 50px rgba(159, 57, 49, 0.34);
  }

  .chevron {
    width: 1.25rem;
    height: 1.25rem;
  }

  .btn-secondary {
    background-color: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.24);
    color: var(--brand-white);
    padding: 1rem 1.4rem;
    border-radius: 999px;
    font-size: 0.98rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-secondary:hover {
    background-color: rgba(255, 255, 255, 0.14);
  }

  .hero-sectors {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin: 2rem 0;
  }

  .hero-sectors span {
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.8);
    padding: 0.65rem 0.85rem;
    border-radius: 999px;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .stats {
    margin-top: 1.2rem;
    display: grid;
    gap: 1rem;
    padding-top: 1.35rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid rgba(255, 255, 255, 0.14);
  }

  .stat-item {
    text-align: left;
    padding-right: 0.4rem;
  }

  .stat-number {
    font-size: 1.55rem;
    font-weight: 800;
    letter-spacing: -0.05em;
    margin-bottom: 0.4rem;
  }

  .stat-label {
    font-size: 0.86rem;
    color: rgba(255, 255, 255, 0.7);
  }

  .hero-panel {
    justify-self: end;
    width: min(100%, 25rem);
    padding: 1.55rem;
    border-radius: 1.6rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.14),
      rgba(255, 255, 255, 0.07)
    );
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    color: var(--brand-white);
    box-shadow: var(--shadow-strong);
  }

  .panel-tag {
    display: inline-flex;
    margin-bottom: 1rem;
    padding: 0.5rem 0.75rem;
    border-radius: 999px;
    background: rgba(240, 219, 191, 0.15);
    color: #f0dbbf;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.88rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .panel-title {
    font-size: 1.55rem;
    line-height: 1.15;
    letter-spacing: -0.04em;
    margin-bottom: 0.85rem;
  }

  .panel-description {
    font-size: 0.96rem;
    color: rgba(255, 255, 255, 0.74);
    margin-bottom: 1.4rem;
  }

  .panel-list {
    display: grid;
    gap: 0.85rem;
  }

  .panel-item {
    padding: 1rem;
    border-radius: 1rem;
    background: rgba(15, 23, 42, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .panel-label {
    display: block;
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.56);
    margin-bottom: 0.3rem;
  }

  .panel-value {
    display: block;
    font-size: 1rem;
    line-height: 1.45;
    font-weight: 600;
  }

  .panel-footer {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .panel-footer-label {
    display: block;
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.56);
    margin-bottom: 0.35rem;
  }

  .panel-footer-value {
    display: block;
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.95rem;
  }

  @media (min-width: 640px) {
    .hero-content {
      padding: 0 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-content {
      padding: 0 2rem;
      grid-template-columns: minmax(0, 1.15fr) minmax(300px, 0.7fr);
    }
  }

  @media (min-width: 901px) and (max-width: 1023px) {
    .hero-panel {
      width: 100%;
      justify-self: stretch;
      padding: 1.7rem;
    }

    .panel-title {
      max-width: 34rem;
    }

    .panel-description {
      max-width: 42rem;
      margin-bottom: 1.1rem;
    }

    .panel-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .panel-footer {
      margin-top: 1.15rem;
    }

    .panel-item:last-child {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 900px) {
    .hero-container {
      padding-top: 10rem;
    }

    .stats {
      grid-template-columns: 1fr;
    }

    .hero-panel {
      width: 100%;
      max-width: none;
      justify-self: stretch;
    }
  }

  @media (max-width: 560px) {
    .hero-container {
      min-height: auto;
      padding-top: 9rem;
      padding-bottom: 2.4rem;
    }

    .hero-content {
      gap: 1.6rem;
    }

    .eyebrow {
      font-size: 0.82rem;
      letter-spacing: 0.12em;
      margin-bottom: 1rem;
    }

    .hero-title {
      font-size: 2.25rem;
      margin-bottom: 1rem;
    }

    .hero-description {
      font-size: 0.96rem;
      margin-bottom: 1.35rem;
    }

    .hero-buttons {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .btn-primary,
    .btn-secondary {
      width: 100%;
      padding: 0.95rem 1.1rem;
      font-size: 0.94rem;
    }

    .hero-sectors {
      gap: 0.55rem;
      margin: 1.4rem 0;
    }

    .hero-sectors span {
      font-size: 0.72rem;
      padding: 0.56rem 0.7rem;
    }

    .stats {
      gap: 0.9rem;
      padding-top: 1rem;
    }

    .stat-number {
      font-size: 1.35rem;
    }

    .stat-label {
      font-size: 0.8rem;
    }

    .hero-panel {
      padding: 1.15rem;
      border-radius: 1.2rem;
    }

    .panel-tag {
      font-size: 0.78rem;
      letter-spacing: 0.12em;
    }

    .panel-title {
      font-size: 1.3rem;
    }

    .panel-description,
    .panel-footer-value {
      font-size: 0.9rem;
    }

    .panel-item {
      padding: 0.85rem;
    }
  }

  @media (max-width: 380px) {
    .hero-title {
      font-size: 2rem;
    }
  }
</style>
