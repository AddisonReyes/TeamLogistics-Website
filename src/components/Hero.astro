---
// Hero.astro
---

<section id="home" class="hero-container">
  <div class="hero-background">
    <img
      src="https://images.unsplash.com/photo-1663801563712-ebf3c6a78239?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxjYXJnbyUyMHNoaXAlMjBvY2VhbnxlbnwxfHx8fDE3NzAyNjk3OTN8MA&ixlib=rb-4.1.0&q=80&w=1920"
      alt="Cargo Ship Logistics"
      class="hero-image"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content">
    <div class="hero-text">
      <div class="badge">
        <span class="badge-dot">
          <span class="ping"></span>
          <span class="dot"></span>
        </span>
        LOGÍSTICA SIN LÍMITES
      </div>

      <h1 class="hero-title">
        Optimiza tus costos con <span class="highlight">Consolidación</span> de Carga
        Inteligente
      </h1>

      <p class="hero-description">
        Especialistas en envíos LCL en República Dominicana. Paga solo por el
        espacio que usas, nosotros nos encargamos del resto.
      </p>

      <div class="hero-buttons">
        <a href="#contacto" class="btn-primary">
          Ver Tarifas de Envío
          <svg
            class="chevron"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </a>
        <a href="#servicios" class="btn-secondary"> Nuestros Servicios </a>
      </div>

      <div class="stats">
        <div class="stat-item">
          <div class="stat-number">15+</div>
          <div class="stat-label">Años Experiencia</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">200+</div>
          <div class="stat-label">Puertos Globales</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">24/7</div>
          <div class="stat-label">Monitoreo Real</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  section {
    padding-bottom: 80px;
    padding-top: 160px;
    height: 100%;
  }

  .hero-container {
    position: relative;
    min-height: 700px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(0, 51, 102, 0.9),
      rgba(0, 51, 102, 0.6),
      transparent
    );
  }

  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1rem;
    width: 100%;
  }

  .hero-text {
    max-width: 42rem;
    color: white;
    animation: fadeInLeft 0.8s ease-out;
  }

  @keyframes fadeInLeft {
    from {
      opacity: 0;
      transform: translateX(-50px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0.75rem;
    background-color: #dc2626;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    position: relative;
    display: flex;
    height: 0.5rem;
    width: 0.5rem;
  }

  .ping {
    position: absolute;
    display: inline-flex;
    height: 100%;
    width: 100%;
    border-radius: 9999px;
    background-color: white;
    opacity: 0.75;
    animation: ping 1s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  @keyframes ping {
    75%,
    100% {
      transform: scale(2);
      opacity: 0;
    }
  }

  .dot {
    position: relative;
    display: inline-flex;
    border-radius: 9999px;
    height: 0.5rem;
    width: 0.5rem;
    background-color: white;
  }

  .hero-title {
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .highlight {
    color: #dc2626;
  }

  .hero-description {
    font-size: 1.25rem;
    color: #f3f4f6;
    margin-bottom: 2rem;
    font-weight: 300;
  }

  .hero-buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .btn-primary {
    background-color: #dc2626;
    color: white;
    padding: 1rem 2rem;
    border-radius: 0.5rem;
    font-size: 1.125rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
  }

  .btn-primary:hover {
    background-color: rgba(220, 38, 38, 0.9);
    box-shadow: 0 10px 15px -3px rgba(220, 38, 38, 0.2);
    transform: translateY(-4px);
  }

  .chevron {
    width: 1.25rem;
    height: 1.25rem;
  }

  .btn-secondary {
    background-color: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: white;
    padding: 1rem 2rem;
    border-radius: 0.5rem;
    font-size: 1.125rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-secondary:hover {
    background-color: rgba(255, 255, 255, 0.2);
  }

  .stats {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
  }

  .stat-item {
    text-align: left;
  }

  .stat-number {
    font-size: 1.875rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .stat-label {
    font-size: 0.875rem;
    color: #d1d5db;
  }

  @media (min-width: 640px) {
    .hero-content {
      padding: 0 1.5rem;
    }

    .hero-buttons {
      flex-direction: row;
    }
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 3.75rem;
    }

    .hero-description {
      font-size: 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-content {
      padding: 0 2rem;
    }
  }
</style>
