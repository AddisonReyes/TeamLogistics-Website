---
import Icon from "./common/Icon.astro";

interface QuoteContactDetail {
  icon: "map-pin" | "package";
  label: string;
  value: string;
}

interface ContactMethod {
  icon: "mail" | "phone" | "send";
  label: string;
  value: string;
  description: string;
  href: string;
  external?: boolean;
}

const quoteContactDetails = [
  {
    icon: "map-pin",
    label: "Base de operación",
    value: "Santo Domingo, República Dominicana",
  },
  {
    icon: "package",
    label: "Tipo de atención",
    value: "Respuesta comercial en menos de 24 horas",
  },
] satisfies QuoteContactDetail[];

const contactMethods = [
  {
    icon: "mail",
    label: "Correo corporativo",
    value: "admin@teamlogistic.net",
    description: "Para cotizaciones, seguimiento comercial y consultas generales.",
    href: "mailto:admin@teamlogistic.net",
  },
  {
    icon: "send",
    label: "WhatsApp",
    value: "Contacto inmediato",
    description: "Converse con el equipo por mensaje directo.",
    href: "https://wa.me/message/LD6T4PHQNNRWL1",
    external: true,
  },
  {
    icon: "phone",
    label: "Teléfono",
    value: "+1 (809) 285-7665",
    description: "Atención directa para coordinar su operación.",
    href: "tel:+18092857665",
  },
] satisfies ContactMethod[];
---

<section id="contact" class="quote-section">
  <div class="container">
    <div class="quote-card">
      <div class="info-column">
        <div class="info-content">
          <div>
            <span class="info-kicker">Contacto profesional</span>
            <h3 class="info-title">
              Cuéntenos su operación y coordinamos el siguiente paso
            </h3>
            <p class="info-description">
              Si desea conversar sobre origen, destino, modalidad o tiempos de
              respuesta, puede escribirnos o llamarnos directamente por el
              canal que le resulte más cómodo.
            </p>

            <div class="contact-items">
              {
                quoteContactDetails.map((detail) => (
                  <div class="contact-item">
                    <div class="contact-icon">
                      <Icon name={detail.icon} size={24} />
                    </div>
                    <div>
                      <div class="contact-label">{detail.label}</div>
                      <div class="contact-value">{detail.value}</div>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>

      <div class="contact-column">
        <div class="contact-header">
          <span class="contact-kicker">Canales activos</span>
          <h4 class="contact-title">Elija la vía que prefiera</h4>
        </div>

        <div class="method-list">
          {
            contactMethods.map((method) => (
              <a
                href={method.href}
                class="method-card"
                target={method.external ? "_blank" : undefined}
                rel={method.external ? "noreferrer" : undefined}
              >
                <div class="method-icon">
                  <Icon name={method.icon} size={22} />
                </div>
                <div class="method-copy">
                  <div class="method-label">{method.label}</div>
                  <div class="method-value">{method.value}</div>
                  <p class="method-description">{method.description}</p>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .quote-section {
    padding: 6.5rem 0;
    background:
      radial-gradient(
        circle at right top,
        rgba(33, 75, 143, 0.08),
        transparent 20%
      ),
      linear-gradient(180deg, #ffffff 0%, #f4f7fb 100%);
    position: relative;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 640px) {
    .container {
      padding: 0 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .container {
      padding: 0 2rem;
    }
  }

  .quote-card {
    background: linear-gradient(135deg, var(--brand-navy) 0%, #17305a 100%);
    border-radius: 1.8rem;
    overflow: hidden;
    box-shadow: var(--shadow-strong);
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(17, 33, 61, 0.14);
  }

  @media (min-width: 1024px) {
    .quote-card {
      flex-direction: row;
    }
  }

  .info-column {
    width: 100%;
    padding: 2.6rem;
    color: var(--brand-white);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  @media (min-width: 1024px) {
    .info-column {
      width: 42%;
      padding: 3.3rem;
    }
  }

  .info-content {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .info-kicker {
    display: inline-flex;
    margin-bottom: 1rem;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    background: rgba(240, 219, 191, 0.12);
    color: #f0dbbf;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.9rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .info-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    margin-bottom: 1.2rem;
    line-height: 1.08;
    letter-spacing: -0.05em;
  }

  .info-description {
    color: rgba(219, 234, 254, 0.84);
    margin-bottom: 2rem;
    font-size: 1rem;
    line-height: 1.85;
  }

  .contact-items {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1rem 1rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .contact-icon {
    width: 3.1rem;
    height: 3.1rem;
    background-color: rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-icon svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .contact-label {
    font-weight: 700;
    margin-bottom: 0.25rem;
    letter-spacing: -0.02em;
  }

  .contact-value {
    color: rgba(219, 234, 254, 0.8);
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .contact-column {
    width: 100%;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), #ffffff);
    padding: 2.6rem;
  }

  @media (min-width: 1024px) {
    .contact-column {
      width: 58%;
      padding: 3.3rem;
    }
  }

  .contact-header {
    margin-bottom: 1.6rem;
  }

  .contact-kicker {
    display: inline-flex;
    margin-bottom: 0.7rem;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.9rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--brand-blue);
  }

  .contact-title {
    font-size: 1.8rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.04em;
    color: var(--brand-ink);
    margin: 0;
  }

  .method-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .method-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
    border-radius: 1.1rem;
    background: #f8fafc;
    border: 1px solid rgba(15, 23, 42, 0.08);
    text-decoration: none;
    color: inherit;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .method-card:hover {
    transform: translateY(-2px);
    border-color: rgba(33, 75, 143, 0.22);
    box-shadow: 0 18px 32px rgba(15, 23, 42, 0.08);
  }

  .method-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 1rem;
    background: rgba(33, 75, 143, 0.08);
    color: var(--brand-blue);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .method-icon svg {
    width: 1.35rem;
    height: 1.35rem;
  }

  .method-copy {
    min-width: 0;
  }

  .method-label {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--brand-muted);
    margin-bottom: 0.3rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .method-value {
    color: var(--brand-ink);
    font-size: 1.05rem;
    font-weight: 800;
    line-height: 1.4;
    word-break: break-word;
  }

  .method-description {
    margin: 0.35rem 0 0;
    color: var(--brand-muted);
    line-height: 1.65;
    font-size: 0.95rem;
  }

  @media (max-width: 560px) {
    .quote-section {
      padding: 5rem 0;
    }

    .quote-card {
      border-radius: 1.25rem;
    }

    .info-column,
    .contact-column {
      padding: 1.4rem;
    }

    .info-content {
      gap: 1.8rem;
    }

    .info-title {
      font-size: 1.8rem;
      margin-bottom: 0.9rem;
    }

    .info-description {
      font-size: 0.94rem;
      line-height: 1.7;
      margin-bottom: 1.4rem;
    }

    .contact-items {
      gap: 1rem;
    }

    .contact-item {
      align-items: flex-start;
      gap: 0.85rem;
      padding: 0.9rem 0 0 0;
    }

    .contact-icon,
    .method-icon {
      width: 2.65rem;
      height: 2.65rem;
      border-radius: 0.85rem;
    }

    .contact-icon svg,
    .method-icon svg {
      width: 1.2rem;
      height: 1.2rem;
    }

    .contact-header {
      margin-bottom: 1.2rem;
    }

    .contact-title {
      font-size: 1.45rem;
    }

    .method-card {
      padding: 1rem;
    }
  }
</style>
