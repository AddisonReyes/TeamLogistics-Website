---
const cargoTypes = [
  "Carga General",
  "Perecederos",
  "Electrónicos",
  "Maquinaria",
  "Otros",
];
---

<section id="contact" class="quote-section">
  <div class="container">
    <div class="quote-card">
      <div class="info-column">
        <div class="info-content">
          <div>
            <span class="info-kicker">Cotización profesional</span>
            <h3 class="info-title">
              Cuéntenos su operación y armamos el mejor siguiente paso
            </h3>
            <p class="info-description">
              Evaluamos origen, destino, modalidad, volumen y necesidades
              documentales para responder con una propuesta más clara y útil.
            </p>

            <div class="contact-items">
              <div class="contact-item">
                <div class="contact-icon">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"
                    ></path>
                    <circle cx="12" cy="10" r="3"></circle>
                  </svg>
                </div>
                <div>
                  <div class="contact-label">Base de operación</div>
                  <div class="contact-value">
                    Santo Domingo, República Dominicana
                  </div>
                </div>
              </div>
              <div class="contact-item">
                <div class="contact-icon">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M16.5 9.4 7.55 4.24"></path>
                    <path
                      d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"
                    ></path>
                    <polyline points="3.29 7 12 12 20.71 7"></polyline>
                    <line x1="12" x2="12" y1="22" y2="12"></line>
                  </svg>
                </div>
                <div>
                  <div class="contact-label">Tipo de atención</div>
                  <div class="contact-value">
                    Respuesta comercial en menos de 24 horas
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="form-column">
        <div class="form-header">
          <span class="form-kicker">Formulario</span>
          <h4 class="form-title">Comparta los datos básicos de su embarque</h4>
        </div>

        <form class="quote-form">
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Nombre Completo</label>
              <input
                type="text"
                class="form-input"
                placeholder="Ej. Carlos Rodríguez"
              />
            </div>
            <div class="form-group">
              <label class="form-label">Correo Electrónico</label>
              <input
                type="email"
                class="form-input"
                placeholder="carlos@empresa.com"
              />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Origen</label>
              <input
                type="text"
                class="form-input"
                placeholder="Ciudad, País"
              />
            </div>
            <div class="form-group">
              <label class="form-label">Destino</label>
              <input
                type="text"
                class="form-input"
                placeholder="Ciudad, País"
              />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Tipo de Carga</label>
              <select class="form-input">
                {cargoTypes.map((type) => <option>{type}</option>)}
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Volumen Estimado (m³)</label>
              <div class="input-with-icon">
                <input
                  type="number"
                  class="form-input"
                  placeholder="0.00"
                  step="0.01"
                />
                <svg
                  class="input-icon"
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"
                  ></path>
                  <path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"
                  ></path>
                  <path d="M7 21h10"></path>
                  <path d="M12 3v18"></path>
                  <path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"></path>
                </svg>
              </div>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">Mensaje Adicional</label>
            <textarea
              rows="4"
              class="form-input"
              placeholder="Cuéntenos más sobre su envío..."></textarea>
          </div>

          <button type="submit" class="submit-button">
            Enviar Solicitud
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="m22 2-7 20-4-9-9-4Z"></path>
              <path d="M22 2 11 13"></path>
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .quote-section {
    padding: 6.5rem 0;
    background:
      radial-gradient(
        circle at right top,
        rgba(33, 75, 143, 0.08),
        transparent 20%
      ),
      linear-gradient(180deg, #ffffff 0%, #f4f7fb 100%);
    position: relative;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 640px) {
    .container {
      padding: 0 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .container {
      padding: 0 2rem;
    }
  }

  .quote-card {
    background: linear-gradient(135deg, var(--brand-navy) 0%, #17305a 100%);
    border-radius: 1.8rem;
    overflow: hidden;
    box-shadow: var(--shadow-strong);
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(17, 33, 61, 0.14);
  }

  @media (min-width: 1024px) {
    .quote-card {
      flex-direction: row;
    }
  }

  .info-column {
    width: 100%;
    padding: 2.6rem;
    color: var(--brand-white);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  @media (min-width: 1024px) {
    .info-column {
      width: 42%;
      padding: 3.3rem;
    }
  }

  .info-content {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .info-kicker {
    display: inline-flex;
    margin-bottom: 1rem;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    background: rgba(240, 219, 191, 0.12);
    color: #f0dbbf;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.9rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .info-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    margin-bottom: 1.2rem;
    line-height: 1.08;
    letter-spacing: -0.05em;
  }

  .info-description {
    color: rgba(219, 234, 254, 0.84);
    margin-bottom: 2rem;
    font-size: 1rem;
    line-height: 1.85;
  }

  .contact-items {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1rem 1rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .contact-icon {
    width: 3.1rem;
    height: 3.1rem;
    background-color: rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-icon svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .contact-label {
    font-weight: 700;
    margin-bottom: 0.25rem;
    letter-spacing: -0.02em;
  }

  .contact-value {
    color: rgba(219, 234, 254, 0.8);
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .trust-panel {
    display: grid;
    gap: 0.9rem;
    padding: 1.2rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 1.3rem;
  }

  .trust-item {
    display: grid;
    gap: 0.3rem;
  }

  .trust-item strong {
    font-size: 0.98rem;
    letter-spacing: -0.02em;
  }

  .trust-item span {
    color: rgba(219, 234, 254, 0.78);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .form-column {
    width: 100%;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), #ffffff);
    padding: 2.6rem;
  }

  @media (min-width: 1024px) {
    .form-column {
      width: 58%;
      padding: 3.3rem;
    }
  }

  .form-header {
    margin-bottom: 1.6rem;
  }

  .form-kicker {
    display: inline-flex;
    margin-bottom: 0.7rem;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.9rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--brand-blue);
  }

  .form-title {
    font-size: 1.8rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.04em;
    color: var(--brand-ink);
  }

  .quote-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .form-row {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .form-group {
    display: flex;
    flex-direction: column;
  }

  .form-label {
    display: block;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--brand-muted);
    margin-bottom: 0.55rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .form-input {
    width: 100%;
    padding: 0.95rem 1rem;
    border-radius: 0.95rem;
    border: 1px solid rgba(15, 23, 42, 0.1);
    background: #f8fafc;
    outline: none;
    transition: all 0.3s ease;
    font-size: 1rem;
    font-family: inherit;
  }

  .form-input:focus {
    border-color: rgba(33, 75, 143, 0.36);
    background: #ffffff;
    box-shadow: 0 0 0 4px rgba(33, 75, 143, 0.12);
  }

  .form-input::placeholder {
    color: #9ca3af;
  }

  textarea.form-input {
    resize: vertical;
    min-height: 100px;
  }

  select.form-input {
    cursor: pointer;
    appearance: none;
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%236b7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
    background-position: right 0.5rem center;
    background-repeat: no-repeat;
    background-size: 1.5em 1.5em;
    padding-right: 2.5rem;
  }

  .input-with-icon {
    position: relative;
  }

  .input-icon {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    width: 1.25rem;
    height: 1.25rem;
    color: #9ca3af;
    pointer-events: none;
  }

  .submit-button {
    width: 100%;
    background: linear-gradient(135deg, var(--brand-red), #9e352f);
    color: var(--brand-white);
    padding: 1rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: 1rem;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    box-shadow: 0 18px 32px rgba(159, 57, 49, 0.22);
  }

  .submit-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 24px 40px rgba(159, 57, 49, 0.28);
  }

  .submit-button svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  @media (max-width: 560px) {
    .quote-section {
      padding: 5rem 0;
    }

    .quote-card {
      border-radius: 1.25rem;
    }

    .info-column,
    .form-column {
      padding: 1.4rem;
    }

    .info-content {
      gap: 1.8rem;
    }

    .info-title {
      font-size: 1.8rem;
      margin-bottom: 0.9rem;
    }

    .info-description {
      font-size: 0.94rem;
      line-height: 1.7;
      margin-bottom: 1.4rem;
    }

    .contact-items {
      gap: 1rem;
    }

    .contact-item {
      align-items: flex-start;
      gap: 0.85rem;
      padding: 0.9rem 0 0 0;
    }

    .contact-icon {
      width: 2.65rem;
      height: 2.65rem;
      border-radius: 0.85rem;
    }

    .contact-icon svg {
      width: 1.2rem;
      height: 1.2rem;
    }

    .trust-panel {
      padding: 1rem;
      border-radius: 1rem;
    }

    .form-header {
      margin-bottom: 1.2rem;
    }

    .form-title {
      font-size: 1.45rem;
    }

    .quote-form {
      gap: 1rem;
    }

    .form-row {
      gap: 1rem;
    }

    .form-label {
      font-size: 0.75rem;
    }

    .form-input {
      padding: 0.9rem 0.95rem;
      font-size: 0.95rem;
    }

    textarea.form-input {
      min-height: 92px;
    }

    .submit-button {
      padding: 0.95rem;
      font-size: 0.95rem;
    }
  }
</style>
