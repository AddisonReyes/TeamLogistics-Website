---
import Icon from "./common/Icon.astro";

type ServiceAccent = "navy" | "red" | "sand";
type ServiceIcon =
  | "ship"
  | "plane"
  | "truck"
  | "warehouse"
  | "globe"
  | "shield";

interface Service {
  accent: ServiceAccent;
  description: string;
  icon: ServiceIcon;
  meta: string;
  title: string;
}

const services = [
  {
    icon: "ship",
    title: "Carga Marítima LCL",
    description:
      "Consolidación marítima para embarques que necesitan estructura, frecuencia y costos mejor distribuidos.",
    meta: "Ideal para importadores con carga parcial",
    accent: "navy",
  },
  {
    icon: "plane",
    title: "Carga Aérea Express",
    description:
      "Alternativa ágil para mercancía prioritaria, reposiciones críticas o operaciones con ventana de entrega corta.",
    meta: "Prioridad en tiempos y coordinación",
    accent: "red",
  },
  {
    icon: "truck",
    title: "Transporte Terrestre",
    description:
      "Cobertura para movimientos nacionales y regionales con seguimiento y coordinación puerta a puerta.",
    meta: "Última milla y distribución regional",
    accent: "sand",
  },
  {
    icon: "warehouse",
    title: "Almacenaje Seguro",
    description:
      "Espacios operativos para recibir, clasificar y preparar mercancía antes de su despacho o entrega.",
    meta: "Control previo al despacho",
    accent: "navy",
  },
  {
    icon: "globe",
    title: "Import / Export",
    description:
      "Acompañamiento documental y operativo para que cada movimiento internacional llegue bien preparado.",
    meta: "Soporte documental y comercial",
    accent: "red",
  },
  {
    icon: "shield",
    title: "Seguro de Carga",
    description:
      "Coberturas pensadas para reducir exposición y proteger el valor de la mercancía en tránsito.",
    meta: "Mitigación de riesgo logístico",
    accent: "sand",
  },
] satisfies Service[];
---

<section id="services" class="services-section">
  <div class="container">
    <div class="header">
      <h2 class="subtitle">Soluciones</h2>
      <h3 class="title">
        Servicios pensados para operar con más orden y menos fricción
      </h3>
      <p class="description">
        Cubrimos la operación completa con un enfoque comercial, documental y de
        ejecución para que cada embarque tenga alcance claro desde el inicio.
      </p>
    </div>

    <div class="services-grid">
      {
        services.map((service, index) => (
          <article class={`service-card ${service.accent}`}>
            <div class="service-topline">
              <span class="service-index">0{index + 1}</span>
              <span class="service-meta">{service.meta}</span>
            </div>
            <div class="service-icon-row">
              <div class="icon-container">
                <Icon name={service.icon} class="icon" size={32} />
              </div>
            </div>
            <h4 class="service-title">{service.title}</h4>
            <p class="service-description">{service.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .services-section {
    padding: 6.5rem 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, #ffffff 20%);
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 640px) {
    .container {
      padding: 0 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .container {
      padding: 0 2rem;
    }
  }

  .header {
    display: grid;
    gap: 1rem;
    max-width: 44rem;
    margin-bottom: 3.75rem;
  }

  .subtitle {
    font-family: "Barlow Condensed", sans-serif;
    color: var(--brand-blue);
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .title {
    font-size: clamp(2rem, 5vw, 3.4rem);
    font-weight: 800;
    letter-spacing: -0.05em;
    line-height: 1.05;
    color: var(--brand-ink);
  }

  .description {
    font-size: 1.02rem;
    color: var(--brand-muted);
    max-width: 38rem;
    line-height: 1.8;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.3rem;
  }

  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1120px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .service-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-height: 100%;
    padding: 1.7rem;
    border-radius: 1.4rem;
    border: 1px solid var(--brand-border);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.94), #ffffff);
    box-shadow: var(--shadow-soft);
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease;
  }

  .service-card::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 4px;
    border-radius: 1.4rem 0 0 1.4rem;
    background: var(--service-accent);
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 50px rgba(15, 23, 42, 0.12);
    border-color: rgba(33, 75, 143, 0.14);
  }

  .service-card.navy {
    --service-accent: var(--brand-blue);
  }

  .service-card.red {
    --service-accent: var(--brand-red);
  }

  .service-card.sand {
    --service-accent: #b08a56;
  }

  .service-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .service-index {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 1rem;
    letter-spacing: 0.16em;
    color: var(--service-accent);
  }

  .service-meta {
    font-size: 0.76rem;
    color: var(--brand-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-align: right;
  }

  .service-icon-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .icon-container {
    width: 3.75rem;
    height: 3.75rem;
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--service-accent) 12%, white);
    color: var(--service-accent);
  }

  .icon {
    width: 1.8rem;
    height: 1.8rem;
  }

  .service-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--brand-ink);
    letter-spacing: -0.03em;
  }

  .service-description {
    color: var(--brand-muted);
    line-height: 1.75;
  }

  @media (max-width: 560px) {
    .services-section {
      padding: 5rem 0;
    }

    .header {
      gap: 0.8rem;
      margin-bottom: 2.5rem;
    }

    .title {
      font-size: 1.85rem;
    }

    .description {
      font-size: 0.95rem;
      line-height: 1.7;
    }

    .services-grid {
      gap: 1rem;
    }

    .service-card {
      padding: 1.25rem;
      border-radius: 1.1rem;
    }

    .service-topline {
      gap: 0.6rem;
      align-items: flex-start;
    }

    .service-meta {
      font-size: 0.7rem;
    }

    .icon-container {
      width: 3.2rem;
      height: 3.2rem;
      border-radius: 0.85rem;
    }

    .icon {
      width: 1.5rem;
      height: 1.5rem;
    }

    .service-title {
      font-size: 1.08rem;
    }

    .service-description {
      font-size: 0.92rem;
      line-height: 1.65;
    }
  }
</style>
