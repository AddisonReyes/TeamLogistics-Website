---
import Icon from "./Icon.astro";

interface FooterContactDetail {
  icon: "mail" | "map-pin" | "phone";
  value: string;
}

const footerQuickLinks = [
  { href: "#home", label: "Inicio" },
  { href: "#services", label: "Nuestros Servicios" },
  { href: "#about", label: "Sobre Nosotros" },
  { href: "#contact", label: "Cotizar Envío" },
  { href: "#faq", label: "Preguntas Frecuentes" },
];

const footerServices = [
  { href: "#", label: "Carga Marítima LCL" },
  { href: "#", label: "Transporte Terrestre" },
  { href: "#", label: "Carga Aérea" },
  { href: "#", label: "Aduanas y Trámites" },
  { href: "#", label: "Almacenaje" },
];

const footerContactDetails = [
  {
    icon: "map-pin",
    value: "Av. Winston Churchill, Santo Domingo, Rep. Dom.",
  },
  {
    icon: "phone",
    value: "+1 (809) 555-0123",
  },
  {
    icon: "mail",
    value: "info@teamlogistics.com.do",
  },
] satisfies FooterContactDetail[];
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-column">
        <span class="logo-text">Team Logistics ALZ, SRL</span>
        <p class="company-description">
          Coordinamos carga con una mirada más profesional del proceso:
          consolidación, documentación, tránsito y entrega con soporte local.
        </p>
      </div>

      <div class="footer-column">
        <h4 class="footer-title">Enlaces Rápidos</h4>
        <ul class="footer-list">
          {
            footerQuickLinks.map((link) => (
              <li>
                <a href={link.href} class="footer-link">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="footer-column">
        <h4 class="footer-title">Servicios</h4>
        <ul class="footer-list">
          {
            footerServices.map((service) => (
              <li>
                <a href={service.href} class="footer-link">
                  {service.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="footer-column">
        <h4 class="footer-title">Contacto</h4>
        <ul class="footer-list contact-list">
          {
            footerContactDetails.map((detail) => (
              <li class="contact-item">
                <Icon name={detail.icon} class="contact-icon" size={20} />
                <span>{detail.value}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-meta">
        <p class="copyright">
          © 2026 Team Logistics. Todos los derechos reservados.
        </p>
        <p class="credit">
          Hecho por <a
            href="https://addisonreyes.com"
            target="_blank"
            rel="noreferrer">Addison Reyes</a
          >
        </p>
      </div>
      <div class="legal-links">
        <a href="#" class="legal-link">Política de Privacidad</a>
        <a href="#" class="legal-link">Términos de Servicio</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background:
      radial-gradient(
        circle at top left,
        rgba(33, 75, 143, 0.18),
        transparent 25%
      ),
      #0b1220;
    color: #d1d8e5;
    padding: 4rem 0;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 640px) {
    .container {
      padding: 0 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .container {
      padding: 0 2rem;
    }
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .footer-column {
    display: flex;
    flex-direction: column;
  }

  .logo-text {
    font-size: 1.25rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.03em;
  }

  .company-description {
    font-size: 0.92rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .footer-title {
    color: #ffffff;
    font-weight: 700;
    margin-bottom: 1.5rem;
    font-size: 1rem;
  }

  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-list li {
    font-size: 0.875rem;
  }

  .footer-link {
    color: #d1d5db;
    transition: color 0.3s ease;
    text-decoration: none;
  }

  .footer-link:hover {
    color: #f0dbbf;
  }

  .contact-list {
    gap: 1rem;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .contact-icon {
    width: 1.25rem;
    height: 1.25rem;
    color: #f0dbbf;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .footer-bottom {
    padding-top: 3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .copyright {
    font-size: 0.75rem;
    color: #8e99ae;
    margin: 0;
  }

  .footer-meta {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .credit {
    margin: 0;
    font-size: 0.72rem;
    color: #748198;
  }

  .credit a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid rgba(240, 219, 191, 0.25);
    transition:
      color 0.25s ease,
      border-color 0.25s ease;
  }

  .credit a:hover {
    color: #f0dbbf;
    border-color: rgba(240, 219, 191, 0.75);
  }

  .legal-links {
    display: flex;
    gap: 2rem;
  }

  .legal-link {
    font-size: 0.75rem;
    color: #8e99ae;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .legal-link:hover {
    color: #ffffff;
  }

  @media (max-width: 560px) {
    .footer {
      padding: 3.2rem 0;
    }

    .footer-grid {
      gap: 2rem;
      margin-bottom: 2rem;
    }

    .logo-text {
      font-size: 1.1rem;
    }

    .company-description {
      font-size: 0.88rem;
      line-height: 1.7;
    }

    .footer-title {
      margin-bottom: 1rem;
    }

    .footer-list {
      gap: 0.8rem;
    }

    .footer-bottom {
      align-items: flex-start;
      gap: 1rem;
      padding-top: 2rem;
    }

    .legal-links {
      flex-direction: column;
      gap: 0.7rem;
    }
  }
</style>
