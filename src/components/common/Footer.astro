---
const quickLinks = [
  { href: "#inicio", label: "Inicio" },
  { href: "#servicios", label: "Nuestros Servicios" },
  { href: "#nosotros", label: "Sobre Nosotros" },
  { href: "#contacto", label: "Cotizar Envío" },
  { href: "#faq", label: "Preguntas Frecuentes" },
];

const services = [
  { href: "#", label: "Carga Marítima LCL" },
  { href: "#", label: "Transporte Terrestre" },
  { href: "#", label: "Carga Aérea" },
  { href: "#", label: "Aduanas y Trámites" },
  { href: "#", label: "Almacenaje" },
];

const socialLinks = [
  {
    href: "#",
    name: "LinkedIn",
    icon: "linkedin",
  },
  {
    href: "#",
    name: "Facebook",
    icon: "facebook",
  },
  {
    href: "#",
    name: "Instagram",
    icon: "instagram",
  },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Company Info -->
      <div class="footer-column">
        <div class="logo-container">
          <div class="logo-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"
              ></path>
              <path d="M15 18H9"></path>
              <path
                d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"
              ></path>
              <circle cx="17" cy="18" r="2"></circle>
              <circle cx="7" cy="18" r="2"></circle>
            </svg>
          </div>
          <span class="logo-text">TEAM LOGISTICS</span>
        </div>
        <p class="company-description">
          Su socio estratégico en logística integral. Especialistas en
          consolidación de carga en República Dominicana y el Caribe. Conectando
          negocios con eficiencia y ahorro.
        </p>
        <div class="social-links">
          {
            socialLinks.map((social) => (
              <a
                href={social.href}
                class="social-link"
                aria-label={social.name}
              >
                {social.icon === "linkedin" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                    <rect width="4" height="12" x="2" y="9" />
                    <circle cx="4" cy="4" r="2" />
                  </svg>
                )}
                {social.icon === "facebook" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
                  </svg>
                )}
                {social.icon === "instagram" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <rect width="20" height="20" x="2" y="2" rx="5" ry="5" />
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                    <line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />
                  </svg>
                )}
              </a>
            ))
          }
        </div>
      </div>

      <!-- Quick Links -->
      <div class="footer-column">
        <h4 class="footer-title">Enlaces Rápidos</h4>
        <ul class="footer-list">
          {
            quickLinks.map((link) => (
              <li>
                <a href={link.href} class="footer-link">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Services -->
      <div class="footer-column">
        <h4 class="footer-title">Servicios</h4>
        <ul class="footer-list">
          {
            services.map((service) => (
              <li>
                <a href={service.href} class="footer-link">
                  {service.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer-column">
        <h4 class="footer-title">Contacto</h4>
        <ul class="footer-list contact-list">
          <li class="contact-item">
            <svg
              class="contact-icon"
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span>Av. Winston Churchill, Santo Domingo, Rep. Dom.</span>
          </li>
          <li class="contact-item">
            <svg
              class="contact-icon"
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path>
            </svg>
            <span>+1 (809) 555-0123</span>
          </li>
          <li class="contact-item">
            <svg
              class="contact-icon"
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect width="20" height="16" x="2" y="4" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            <span>info@teamlogistics.com.do</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p class="copyright">
        © 2026 Team Logistics. Todos los derechos reservados.
      </p>
      <div class="legal-links">
        <a href="#" class="legal-link">Política de Privacidad</a>
        <a href="#" class="legal-link">Términos de Servicio</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #111827;
    color: #d1d5db;
    padding: 4rem 0;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 640px) {
    .container {
      padding: 0 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .container {
      padding: 0 2rem;
    }
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .footer-column {
    display: flex;
    flex-direction: column;
  }

  /* Logo Section */
  .logo-container {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .logo-icon {
    background-color: var(--brand-blue, #1e40af);
    padding: 0.5rem;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-icon svg {
    color: #ffffff;
    width: 1.25rem;
    height: 1.25rem;
  }

  .logo-text {
    font-size: 1.25rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.025em;
  }

  .company-description {
    font-size: 0.875rem;
    line-height: 1.625;
    margin-bottom: 1.5rem;
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-link {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    color: #d1d5db;
  }

  .social-link:hover {
    background-color: var(--brand-blue, #1e40af);
    color: #ffffff;
    transform: translateY(-2px);
  }

  /* Footer Lists */
  .footer-title {
    color: #ffffff;
    font-weight: 700;
    margin-bottom: 1.5rem;
    font-size: 1rem;
  }

  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-list li {
    font-size: 0.875rem;
  }

  .footer-link {
    color: #d1d5db;
    transition: color 0.3s ease;
    text-decoration: none;
  }

  .footer-link:hover {
    color: var(--brand-blue, #1e40af);
  }

  /* Contact List */
  .contact-list {
    gap: 1rem;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .contact-icon {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--brand-red, #dc2626);
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  /* Bottom Bar */
  .footer-bottom {
    padding-top: 3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .copyright {
    font-size: 0.75rem;
    color: #6b7280;
    margin: 0;
  }

  .legal-links {
    display: flex;
    gap: 2rem;
  }

  .legal-link {
    font-size: 0.75rem;
    color: #6b7280;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .legal-link:hover {
    color: #ffffff;
  }
</style>
