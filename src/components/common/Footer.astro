---
const quickLinks = [
  { href: "#home", label: "Inicio" },
  { href: "#services", label: "Nuestros Servicios" },
  { href: "#about", label: "Sobre Nosotros" },
  { href: "#contact", label: "Cotizar Envío" },
  { href: "#faq", label: "Preguntas Frecuentes" },
];

const services = [
  { href: "#", label: "Carga Marítima LCL" },
  { href: "#", label: "Transporte Terrestre" },
  { href: "#", label: "Carga Aérea" },
  { href: "#", label: "Aduanas y Trámites" },
  { href: "#", label: "Almacenaje" },
];

const socialLinks = [
  {
    href: "#",
    name: "LinkedIn",
    icon: "linkedin",
  },
  {
    href: "#",
    name: "Facebook",
    icon: "facebook",
  },
  {
    href: "#",
    name: "Instagram",
    icon: "instagram",
  },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-column">
        <span class="logo-text">Team Logistics ALZ, SRL</span>
        <p class="company-description">
          Coordinamos carga con una mirada más profesional del proceso:
          consolidación, documentación, tránsito y entrega con soporte local.
        </p>
      </div>

      <div class="footer-column">
        <h4 class="footer-title">Enlaces Rápidos</h4>
        <ul class="footer-list">
          {
            quickLinks.map((link) => (
              <li>
                <a href={link.href} class="footer-link">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="footer-column">
        <h4 class="footer-title">Servicios</h4>
        <ul class="footer-list">
          {
            services.map((service) => (
              <li>
                <a href={service.href} class="footer-link">
                  {service.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="footer-column">
        <h4 class="footer-title">Contacto</h4>
        <ul class="footer-list contact-list">
          <li class="contact-item">
            <svg
              class="contact-icon"
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span>Av. Winston Churchill, Santo Domingo, Rep. Dom.</span>
          </li>
          <li class="contact-item">
            <svg
              class="contact-icon"
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path>
            </svg>
            <span>+1 (809) 555-0123</span>
          </li>
          <li class="contact-item">
            <svg
              class="contact-icon"
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect width="20" height="16" x="2" y="4" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            <span>info@teamlogistics.com.do</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-meta">
        <p class="copyright">
          © 2026 Team Logistics. Todos los derechos reservados.
        </p>
        <p class="credit">
          Hecho por <a
            href="https://addisonreyes.com"
            target="_blank"
            rel="noreferrer">Addison Reyes</a
          >
        </p>
      </div>
      <div class="legal-links">
        <a href="#" class="legal-link">Política de Privacidad</a>
        <a href="#" class="legal-link">Términos de Servicio</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background:
      radial-gradient(
        circle at top left,
        rgba(33, 75, 143, 0.18),
        transparent 25%
      ),
      #0b1220;
    color: #d1d8e5;
    padding: 4rem 0;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 640px) {
    .container {
      padding: 0 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .container {
      padding: 0 2rem;
    }
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .footer-column {
    display: flex;
    flex-direction: column;
  }

  /* Logo Section */
  .logo-container {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 1.2rem;
  }

  .logo-icon {
    background: linear-gradient(135deg, var(--brand-blue), var(--brand-navy));
    padding: 0.7rem;
    border-radius: 0.85rem;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 18px 30px rgba(17, 33, 61, 0.35);
  }

  .logo-icon svg {
    color: #ffffff;
    width: 1.25rem;
    height: 1.25rem;
  }

  .logo-text {
    font-size: 1.25rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.03em;
  }

  .company-description {
    font-size: 0.92rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .footer-cta {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    padding: 0.95rem 1.2rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    text-decoration: none;
    color: #ffffff;
    font-weight: 600;
    transition:
      transform 0.25s ease,
      background 0.25s ease;
  }

  .footer-cta:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.1);
  }

  .footer-title {
    color: #ffffff;
    font-weight: 700;
    margin-bottom: 1.5rem;
    font-size: 1rem;
  }

  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-list li {
    font-size: 0.875rem;
  }

  .footer-link {
    color: #d1d5db;
    transition: color 0.3s ease;
    text-decoration: none;
  }

  .footer-link:hover {
    color: #f0dbbf;
  }

  .contact-list {
    gap: 1rem;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .contact-icon {
    width: 1.25rem;
    height: 1.25rem;
    color: #f0dbbf;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .footer-bottom {
    padding-top: 3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .copyright {
    font-size: 0.75rem;
    color: #8e99ae;
    margin: 0;
  }

  .footer-meta {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .credit {
    margin: 0;
    font-size: 0.72rem;
    color: #748198;
  }

  .credit a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid rgba(240, 219, 191, 0.25);
    transition:
      color 0.25s ease,
      border-color 0.25s ease;
  }

  .credit a:hover {
    color: #f0dbbf;
    border-color: rgba(240, 219, 191, 0.75);
  }

  .legal-links {
    display: flex;
    gap: 2rem;
  }

  .legal-link {
    font-size: 0.75rem;
    color: #8e99ae;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .legal-link:hover {
    color: #ffffff;
  }

  @media (max-width: 560px) {
    .footer {
      padding: 3.2rem 0;
    }

    .footer-grid {
      gap: 2rem;
      margin-bottom: 2rem;
    }

    .logo-text {
      font-size: 1.1rem;
    }

    .company-description {
      font-size: 0.88rem;
      line-height: 1.7;
    }

    .footer-title {
      margin-bottom: 1rem;
    }

    .footer-list {
      gap: 0.8rem;
    }

    .footer-bottom {
      align-items: flex-start;
      gap: 1rem;
      padding-top: 2rem;
    }

    .legal-links {
      flex-direction: column;
      gap: 0.7rem;
    }
  }
</style>
