---
const navigationLinks = [
  { href: "#home", label: "Inicio" },
  { href: "#services", label: "Servicios" },
  { href: "#about", label: "Nosotros" },
  { href: "#faq", label: "Preguntas" },
];

const quoteLink = {
  href: "#contact",
  label: "Solicitar cotización",
};
---

<header class="site-header">
  <nav class="nav-shell" aria-label="Principal">
    <a class="brand" href="#home" aria-label="Ir al inicio">
      <img id="logo" src="/tl_logo.png" alt="Team Logistics" />
    </a>

    <button
      class="menu-toggle"
      aria-label="Abrir menú"
      aria-controls="menu"
      aria-expanded="false"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <div class="menu-backdrop"></div>

    <ul class="menu" id="menu">
      {
        navigationLinks.map((link) => (
          <li>
            <a href={link.href} class="nav-link">
              {link.label}
            </a>
          </li>
        ))
      }
      <li>
        <a href={quoteLink.href} class="nav-link nav-link--cta">
          {quoteLink.label}
        </a>
      </li>
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 1000;
    padding: 1.1rem 1rem 0;
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
  }

  .nav-shell {
    width: min(1280px, 100%);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.9rem 1.15rem;
    border: 1px solid rgba(255, 255, 255, 0.55);
    border-radius: 1.3rem;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.92),
      rgba(255, 255, 255, 0.86)
    );
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
  }

  .brand {
    display: flex;
    align-items: center;
    text-decoration: none;
    min-width: 0;
  }

  #logo {
    width: 160px;
    object-fit: contain;
    border-radius: 14px;
    flex-shrink: 0;
  }

  .menu {
    align-items: center;
    list-style: none;
    display: flex;
    gap: 1.2rem;
  }

  nav li {
    display: inline-flex;
    align-items: center;
  }

  .nav-link {
    position: relative;
    text-decoration: none;
    color: var(--brand-muted);
    font-weight: 600;
    font-size: 0.94rem;
    letter-spacing: -0.02em;
    transition: color 0.25s ease;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -0.35rem;
    width: 100%;
    height: 2px;
    transform: scaleX(0);
    transform-origin: left;
    background: linear-gradient(90deg, var(--brand-blue), var(--brand-red));
    transition: transform 0.25s ease;
  }

  .nav-link:hover {
    color: var(--brand-ink);
  }

  .nav-link:hover::after {
    transform: scaleX(1);
  }

  .nav-link--cta {
    padding: 0.85rem 1.2rem;
    border-radius: 999px;
    color: var(--brand-white);
    background: linear-gradient(135deg, var(--brand-blue), var(--brand-navy));
    box-shadow: 0 16px 26px rgba(17, 33, 61, 0.18);
  }

  .nav-link--cta::after {
    display: none;
  }

  .nav-link--cta:hover {
    color: var(--brand-white);
    background: linear-gradient(135deg, #2858a7, #162949);
  }

  .menu-toggle {
    background: none;
    flex-direction: column;
    justify-content: space-between;
    border: none;
    cursor: pointer;
    display: none;
    height: 24px;
    width: 30px;
    padding: 0;
    flex-shrink: 0;
  }

  .menu-toggle span {
    transition: all 0.3s ease;
    background-color: var(--brand-ink);
    border-radius: 999px;
    display: block;
    height: 2px;
    width: 100%;
  }

  .menu-toggle.active span:nth-child(1) {
    transform: rotate(45deg) translate(8px, 6px);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translate(8px, -7px);
  }

  .menu-backdrop {
    display: none;
  }

  @media (max-width: 768px) {
    .site-header.is-hidden {
      transform: translateY(calc(-100% - 1rem));
      opacity: 0;
    }

    .site-header {
      padding: 0.7rem 0.7rem 2rem;
    }

    .nav-shell {
      gap: 0.9rem;
      min-height: 6.4rem;
      padding: 0.9rem 1rem;
      border-radius: 1.3rem;
      box-shadow: 0 24px 48px rgba(15, 23, 42, 0.12);
    }

    .menu-toggle {
      display: flex;
      z-index: 1001;
      width: 3.2rem;
      height: 3.2rem;
      padding: 0.8rem 0.7rem;
      align-items: center;
      border-radius: 1rem;
      background: rgba(17, 33, 61, 0.04);
      border: 1px solid rgba(17, 33, 61, 0.1);
    }

    #logo {
      width: 92px;
      height: 58px;
    }

    .menu {
      flex-direction: column;
      align-items: stretch;
      position: absolute;
      top: calc(100% + 0.95rem);
      left: 0;
      right: 0;
      padding: 1rem;
      gap: 0.35rem;
      border-radius: 1.2rem;
      border: 1px solid rgba(255, 255, 255, 0.5);
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 24px 48px rgba(15, 23, 42, 0.12);
      opacity: 0;
      pointer-events: none;
      transform: translateY(-12px);
      transition:
        opacity 0.3s ease,
        transform 0.3s ease;
    }

    .menu.active {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }

    nav li {
      width: 100%;
    }

    .nav-link {
      display: block;
      padding: 0.95rem 1rem;
      font-size: 0.98rem;
      border-radius: 0.9rem;
    }

    .nav-link::after {
      display: none;
    }

    .nav-link:hover {
      background: rgba(33, 75, 143, 0.06);
    }

    .nav-link--cta {
      margin-top: 0.35rem;
      text-align: center;
    }

    .menu-backdrop.active {
      display: block;
      position: fixed;
      inset: 0;
      background: rgba(15, 23, 42, 0.18);
      backdrop-filter: blur(2px);
      -webkit-backdrop-filter: blur(2px);
      z-index: -1;
    }
  }

  @media (max-width: 480px) {
    .site-header {
      padding: 0.6rem 0.6rem 2rem;
    }

    .nav-shell {
      min-height: 5.9rem;
      padding: 0.82rem 0.85rem;
      border-radius: 1.15rem;
    }

    #logo {
      width: 84px;
      height: 52px;
    }

    .menu-toggle {
      width: 3rem;
      height: 3rem;
      padding: 0.72rem 0.64rem;
      border-radius: 0.95rem;
    }

    .menu {
      top: calc(100% + 0.8rem);
      padding: 0.8rem;
    }

    .nav-link {
      padding: 0.9rem 0.9rem;
      font-size: 0.95rem;
    }
  }
</style>

<script>
  const HIDE_THRESHOLD = 120;
  const TOP_RESET_THRESHOLD = 12;

  const siteHeader = document.querySelector<HTMLElement>(".site-header");
  const menuToggle = document.querySelector<HTMLButtonElement>(".menu-toggle");
  const menu = document.querySelector<HTMLElement>(".menu");
  const menuBackdrop = document.querySelector<HTMLElement>(".menu-backdrop");
  const mobileNavbarQuery = window.matchMedia("(max-width: 768px)");
  let lastScrollY = window.scrollY;
  let isTicking = false;

  const setMenuState = (isOpen: boolean) => {
    menuToggle?.classList.toggle("active", isOpen);
    menu?.classList.toggle("active", isOpen);
    menuBackdrop?.classList.toggle("active", isOpen);
    menuToggle?.setAttribute("aria-expanded", String(isOpen));
    siteHeader?.classList.remove("is-hidden");
  };

  const closeMenu = () => setMenuState(false);

  const syncNavbarVisibility = () => {
    if (!siteHeader) {
      isTicking = false;
      return;
    }

    const currentScrollY = window.scrollY;
    const isMenuOpen = menu?.classList.contains("active") ?? false;

    if (!mobileNavbarQuery.matches || isMenuOpen) {
      siteHeader.classList.remove("is-hidden");
      lastScrollY = currentScrollY;
      isTicking = false;
      return;
    }

    const scrollingDown = currentScrollY > lastScrollY;
    const passedHideThreshold = currentScrollY > HIDE_THRESHOLD;

    if (scrollingDown && passedHideThreshold) {
      siteHeader.classList.add("is-hidden");
    } else {
      siteHeader.classList.remove("is-hidden");
    }

    if (currentScrollY <= TOP_RESET_THRESHOLD) {
      siteHeader.classList.remove("is-hidden");
    }

    lastScrollY = currentScrollY;
    isTicking = false;
  };

  menuToggle?.addEventListener("click", () => {
    setMenuState(!(menu?.classList.contains("active") ?? false));
  });

  menu?.addEventListener("click", (event) => {
    const target = event.target as HTMLElement;
    if (target.closest("a")) {
      closeMenu();
    }
  });

  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest("nav")) {
      closeMenu();
    }
  });

  window.addEventListener(
    "scroll",
    () => {
      if (!isTicking) {
        window.requestAnimationFrame(syncNavbarVisibility);
        isTicking = true;
      }
    },
    { passive: true },
  );

  mobileNavbarQuery.addEventListener("change", () => {
    siteHeader?.classList.remove("is-hidden");
    lastScrollY = window.scrollY;
    closeMenu();
  });

  syncNavbarVisibility();
</script>
