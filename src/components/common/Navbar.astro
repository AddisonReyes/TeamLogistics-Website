<header class="site-header">
  <nav class="nav-shell" aria-label="Principal">
    <a class="brand" href="#home" aria-label="Ir al inicio">
      <img id="logo" src="/tl_logo.png" alt="Team Logistics" />
    </a>

    <button
      id="menu-toggle"
      aria-label="Abrir menú"
      aria-controls="menu"
      aria-expanded="false"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <div class="menu-backdrop" id="menu-backdrop"></div>

    <ul id="menu">
      <li>
        <a href="#home">Inicio</a>
      </li>
      <li>
        <a href="#services">Servicios</a>
      </li>
      <li>
        <a href="#about">Nosotros</a>
      </li>
      <li>
        <a href="#faq">Preguntas</a>
      </li>
      <li>
        <a href="#contact" id="btn-quote">Solicitar cotización</a>
      </li>
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 1000;
    padding: 1.1rem 1rem 0;
  }

  .nav-shell {
    width: min(1280px, 100%);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.9rem 1.15rem;
    border: 1px solid rgba(255, 255, 255, 0.55);
    border-radius: 1.3rem;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.92),
      rgba(255, 255, 255, 0.86)
    );
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
  }

  .brand {
    display: flex;
    align-items: center;
    text-decoration: none;
    min-width: 0;
  }

  #logo {
    width: 160px;
    object-fit: contain;
    border-radius: 14px;
    flex-shrink: 0;
  }

  nav ul {
    align-items: center;
    list-style: none;
    display: flex;
    gap: 1.2rem;
  }

  nav li {
    display: inline-flex;
    align-items: center;
  }

  nav a {
    position: relative;
    text-decoration: none;
    color: var(--brand-muted);
    font-weight: 600;
    font-size: 0.94rem;
    letter-spacing: -0.02em;
    transition: color 0.25s ease;
  }

  nav a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -0.35rem;
    width: 100%;
    height: 2px;
    transform: scaleX(0);
    transform-origin: left;
    background: linear-gradient(90deg, var(--brand-blue), var(--brand-red));
    transition: transform 0.25s ease;
  }

  nav a:hover {
    color: var(--brand-ink);
  }

  nav a:hover::after {
    transform: scaleX(1);
  }

  #btn-quote {
    padding: 0.85rem 1.2rem;
    border-radius: 999px;
    color: var(--brand-white);
    background: linear-gradient(135deg, var(--brand-blue), var(--brand-navy));
    box-shadow: 0 16px 26px rgba(17, 33, 61, 0.18);
  }

  #btn-quote::after {
    display: none;
  }

  #btn-quote:hover {
    color: var(--brand-white);
    background: linear-gradient(135deg, #2858a7, #162949);
  }

  #menu-toggle {
    background: none;
    flex-direction: column;
    justify-content: space-between;
    border: none;
    cursor: pointer;
    display: none;
    height: 24px;
    width: 30px;
    padding: 0;
    flex-shrink: 0;
  }

  #menu-toggle span {
    transition: all 0.3s ease;
    background-color: var(--brand-ink);
    border-radius: 999px;
    display: block;
    height: 2px;
    width: 100%;
  }

  #menu-toggle.active span:nth-child(1) {
    transform: rotate(45deg) translate(8px, 6px);
  }

  #menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  #menu-toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translate(8px, -7px);
  }

  .menu-backdrop {
    display: none;
  }

  @media (max-width: 768px) {
    .site-header {
      padding: 0.65rem 0.65rem 0;
    }

    .nav-shell {
      gap: 0.9rem;
      padding: 0.75rem 0.85rem;
      border-radius: 1.1rem;
    }

    #menu-toggle {
      display: flex;
      z-index: 1001;
    }

    #logo {
      width: 86px;
      height: 54px;
    }

    nav ul {
      flex-direction: column;
      align-items: stretch;
      position: absolute;
      top: calc(100% + 0.75rem);
      left: 0;
      right: 0;
      padding: 1rem;
      gap: 0.35rem;
      border-radius: 1.2rem;
      border: 1px solid rgba(255, 255, 255, 0.5);
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 24px 48px rgba(15, 23, 42, 0.12);
      opacity: 0;
      pointer-events: none;
      transform: translateY(-12px);
      transition:
        opacity 0.3s ease,
        transform 0.3s ease;
    }

    nav ul.active {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }

    nav li {
      width: 100%;
    }

    nav a {
      display: block;
      padding: 0.95rem 1rem;
      font-size: 0.98rem;
      border-radius: 0.9rem;
    }

    nav a::after {
      display: none;
    }

    nav a:hover {
      background: rgba(33, 75, 143, 0.06);
    }

    #btn-quote {
      margin-top: 0.35rem;
      text-align: center;
    }

    .menu-backdrop.active {
      display: block;
      position: fixed;
      inset: 0;
      background: rgba(15, 23, 42, 0.18);
      backdrop-filter: blur(2px);
      -webkit-backdrop-filter: blur(2px);
      z-index: -1;
    }
  }

  @media (max-width: 480px) {
    .nav-shell {
      padding: 0.72rem 0.8rem;
    }

    #logo {
      width: 78px;
      height: 48px;
    }

    nav ul {
      top: calc(100% + 0.55rem);
      padding: 0.8rem;
    }

    nav a {
      padding: 0.9rem 0.9rem;
      font-size: 0.95rem;
    }
  }
</style>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("menu");
  const menuBackdrop = document.getElementById("menu-backdrop");

  menuToggle?.addEventListener("click", () => {
    menuToggle.classList.toggle("active");
    menu?.classList.toggle("active");
    menuBackdrop?.classList.toggle("active");
    menuToggle.setAttribute(
      "aria-expanded",
      menuToggle.classList.contains("active") ? "true" : "false",
    );
  });

  const menuLinks = menu?.querySelectorAll("a");
  menuLinks?.forEach((link) => {
    link.addEventListener("click", () => {
      menuToggle?.classList.remove("active");
      menu?.classList.remove("active");
      menuBackdrop?.classList.remove("active");
      menuToggle?.setAttribute("aria-expanded", "false");
    });
  });

  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest("nav")) {
      menuToggle?.classList.remove("active");
      menu?.classList.remove("active");
      menuBackdrop?.classList.remove("active");
      menuToggle?.setAttribute("aria-expanded", "false");
    }
  });
</script>
